{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cancer Early Detection Literature Paper",
  "description": "Schema for individual paper JSON files in the 16-cancer × 5-category survey repository",
  "type": "object",
  "required": [
    "paper_id",
    "title",
    "cancer_type",
    "category",
    "performance_raw",
    "quality_flags"
  ],
  "properties": {
    "paper_id": {
      "type": "string",
      "description": "Unique ID: {cancer}_{category}_{NNN}"
    },
    "pmid": {
      "type": [
        "string",
        "null"
      ],
      "description": "PubMed ID"
    },
    "title": {
      "type": "string"
    },
    "year": {
      "type": [
        "integer",
        "null"
      ]
    },
    "journal": {
      "type": [
        "string",
        "null"
      ]
    },
    "doi": {
      "type": [
        "string",
        "null"
      ]
    },
    "cancer_type": {
      "type": "string",
      "enum": [
        "lung",
        "breast",
        "colorectal",
        "liver",
        "prostate",
        "cervical",
        "ovarian",
        "endometrial",
        "gallbladder",
        "lymphoma",
        "bladder",
        "kidney",
        "pancreas",
        "gastric",
        "esophageal",
        "nasopharyngeal"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "LDCT_traditional",
        "LDCT_LLM",
        "cfDNA_traditional",
        "cfDNA_LDCT_traditional",
        "cfDNA_LDCT_LLM"
      ],
      "description": "LDCT_traditional: CT imaging + classical ML; LDCT_LLM: CT + foundation/LLM; cfDNA_traditional: liquid biopsy + classical ML; cfDNA_LDCT_traditional: multimodal cfDNA+CT + classical ML; cfDNA_LDCT_LLM: multimodal + foundation model"
    },
    "study_design": {
      "type": "string",
      "enum": [
        "RCT",
        "prospective_cohort",
        "retrospective_cohort",
        "case_control",
        "cross_sectional",
        "other"
      ]
    },
    "cohort_type": {
      "type": "string",
      "enum": [
        "screening",
        "clinical",
        "mixed"
      ]
    },
    "sample_size": {
      "type": [
        "integer",
        "null"
      ]
    },
    "input_modalities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_type": {
      "type": "string"
    },
    "performance_raw": {
      "type": "object",
      "properties": {
        "auc": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "sensitivity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "specificity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "early_stage_sensitivity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "has_stage_info": {
      "type": "boolean"
    },
    "validation_type": {
      "type": "string",
      "enum": [
        "external_validation",
        "prospective",
        "internal_CV",
        "none"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "quality_flags": {
      "type": "object",
      "properties": {
        "screening_relevant": {
          "type": "boolean"
        },
        "has_external_validation": {
          "type": "boolean"
        },
        "case_control_design": {
          "type": "boolean"
        },
        "impact_factor": {
          "type": [
            "number",
            "null"
          ]
        },
        "if_above_10": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "if_unknown": {
          "type": "boolean"
        },
        "tier": {
          "type": "string",
          "enum": [
            "core",
            "extended",
            "low_if",
            "unknown"
          ],
          "description": "core: IF>10; extended: IF 5-10; low_if: IF<5; unknown: IF not in lookup table"
        }
      }
    }
  }
}